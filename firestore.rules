rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidReview(data) {
      return data.hospitalName is string && data.hospitalName.size() <= 200 &&
             data.hospitalAddress is string && data.hospitalAddress.size() <= 500 &&
             data.userName is string && data.userName.size() <= 100 &&
             data.userId == request.auth.uid &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 2000 &&
             data.createdAt == request.time;
    }

    match /reviews/{reviewId} {
      allow list: if true; // Public listings
      allow get: if true;
      allow create: if isSignedIn() && isValidReview(incoming());
      allow update: if isOwner(existing().userId) && 
                      isValidReview(incoming()) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'comment', 'createdAt']);
      allow delete: if isOwner(existing().userId);
    }
  }
}
